generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @default(uuid())
  username   String
  email      String   @unique
  password   String   // hashed
  profilePic String?  // base64 image
  status     String?  // null = belum aktif, bisa diisi "aktif"
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  archives   Archive[]
  categories Category[]
}

model Category {
  id        String   @id @default(uuid())
  name      String
  userEmail String
  user      User     @relation(fields: [userEmail], references: [email], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userEmail, name])
}

model Archive {
  id          String   @id @default(uuid())
  userEmail   String
  user        User     @relation(fields: [userEmail], references: [email], onDelete: Cascade)
  fileName    String   // nama asli file (untuk ekstensi)
  customName  String   // nama yang ditampilkan
  category    String
  year        String
  uploadDate  DateTime @default(now())
  driveUrl    String   // preview url (vercel blob)
  downloadUrl String   // download url (vercel blob)
  fileId      String   // blob id / url

  @@index([userEmail])
}